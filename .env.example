# ============================================================
# Variáveis de ambiente — copie este arquivo para .env
# e preencha com seus valores reais.
# NUNCA commite o arquivo .env no GitHub!
# ============================================================

# ID da planilha Google Sheets
# (encontre na URL: docs.google.com/spreadsheets/d/SEU_ID_AQUI/edit)
GOOGLE_SHEETS_ID=seu_spreadsheet_id_aqui

# Caminho para o arquivo JSON da Service Account do Google Cloud
GOOGLE_SERVICE_ACCOUNT_JSON=service_account.json
